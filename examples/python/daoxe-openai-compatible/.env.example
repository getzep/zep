# Zep Cloud — https://app.getzep.com
ZEP_API_KEY=your_zep_api_key_here

# DaoXE OpenAI-compatible gateway — https://daoxe.com
# Not available in mainland China.
DAOXE_API_KEY=your_daoxe_api_key_here

# Exact model ID from your DaoXE account (GET https://daoxe.com/v1/models)
DAOXE_MODEL=your_account_model_id_here

# Optional override (default: https://daoxe.com/v1)
# DAOXE_BASE_URL=https://daoxe.com/v1
